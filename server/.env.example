# PostgreSQL connection string (Railway sets this automatically in production)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jungle_survival?schema=public"

# Secret used to sign JWTs — use a long random string in production
JWT_SECRET="change-me-to-a-long-random-string"

# Port the Express + Socket.io server listens on
PORT=3001

# Allowed CORS origin (your Vercel frontend URL in production)
CLIENT_URL="http://localhost:5173"
